# App
APP_NAME="English Reader"
DEBUG=true
SECRET_KEY="change-this-to-a-random-secret-key-in-production"

# Database
DATABASE_URL="sqlite+aiosqlite:///./english_reader.db"

# Redis
REDIS_URL="redis://localhost:6379/0"
CACHE_TTL_SECONDS=86400   # 24 小時，每日文章 cache

# LLM (選其一填入)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_PROVIDER="anthropic"  # "openai" or "anthropic"

# RSS Sources (逗號分隔)
RSS_FEEDS="http://feeds.bbci.co.uk/news/world/rss.xml,https://feeds.npr.org/1001/rss.xml"

# JWT
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 天
